{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/freshness.js"
          }
        ]
      }
    ],
    "PostToolUse": [],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-skill.js"
          }
        ]
      }
    ]
  },
  "reminders": {
    "_comment": "auto-skill Hook 이 참조. 프로젝트별로 조정 가능.",
    "security_audit_interval_days": 30,
    "cleanup_interval_days": 45,
    "security_sensitive_keywords": [
      "인증", "로그인", "토큰", "세션", "비밀번호", "password",
      "결제", "카드", "환불", "PG", "payment",
      "API 키", "시크릿", "secret", "OAuth",
      "권한", "admin", "관리자"
    ]
  }
}
